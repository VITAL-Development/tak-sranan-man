    "grammarNotes": [
      {
        "id": "srn-gr-possessive-demonstrative",
        "title": "Bezittelijk gebruik en aanwijzende voornaamwoorden",
        "body": "Het bezittelijk voornaamwoord is identiek aan het persoonlijk voornaamwoord: 'mi kondre' betekent 'mijn land'. Disi (deze/dit) en dati (die/dat) worden altijd ná het zelfstandig naamwoord geplaatst: 'a lampu disi' (deze lamp), 'a sani dati' (dat ding). Dati wijst naar iets verder weg dan disi."
      }
    ],
    "exercises": {
      "srn-l4-e5": {
        "kind": "multiple-choice",
        "prompt": "Waar plaats je 'disi' of 'dati' in een zin?",
        "options": [
          "altijd na het zelfstandig naamwoord",
          "altijd voor het zelfstandig naamwoord",
          "aan het begin van de zin",
          "het maakt niet uit"
        ],
        "correctIndex": 0
      },
      "srn-l4-e6": {
        "kind": "matching",
        "prompt": "Koppel elk woord aan de juiste betekenis.",
        "pairs": [
          { "left": "disi", "right": "deze / dit" },
          { "left": "dati", "right": "die / dat (verder weg)" },
          { "left": "mi kondre", "right": "mijn land" }
        ]
      },
      "srn-l4-e7": {
        "kind": "fill-blank",
        "sentenceTemplate": "A sani ___ na fu mi.",
        "correctAnswer": "dati",
        "options": ["dati", "disi", "den", "wan"],
        "translations": { "nl": "Dat ding is van mij." }
      }
    }
  },
