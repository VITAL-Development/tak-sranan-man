    "grammarNotes": [
      {
        "id": "srn-gr-personal-pronouns",
        "title": "Persoonlijke voornaamwoorden",
        "body": "Sranantongo heeft geen naamvallen: mi (ik), yu (jij), a/en (hij/zij/het), wi (wij), unu (jullie), den (zij) blijven hetzelfde, ongeacht de zinspositie — behalve het derde-persoon-enkelvoud, dat als onderwerp 'a' is en als lijdend voorwerp of na een voorzetsel 'en' wordt (bv. 'A naki en' — 'hij sloeg hem')."
      }
    ],
    "exercises": {
